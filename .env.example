# 投稿文生成のLLM切替
# "gemini" = Google Gemini 2.0 Flash（無料）
# "claude" = Anthropic Claude Sonnet 4.6（有料、月120円程度）
LLM_PROVIDER=gemini

# Gemini API（LLM_PROVIDER=gemini のとき使用）
# https://aistudio.google.com/app/apikey で取得
GEMINI_API_KEY=AIzaxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Anthropic API（LLM_PROVIDER=claude のとき使用）
# https://console.anthropic.com/ で取得
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Threads API（投稿）
# https://developers.facebook.com/apps/ で取得
THREADS_USER_ID=1234567890
THREADS_ACCESS_TOKEN=THAAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# LINE Messaging API（承認通知）
# https://developers.line.biz/console/ で取得
LINE_CHANNEL_ACCESS_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
LINE_CHANNEL_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
LINE_USER_ID=Uxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# GitHub（Cloudflare Workersから dispatch するための PAT）
# repo スコープを付与
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GITHUB_REPO=1411998888z-ai/no.1
